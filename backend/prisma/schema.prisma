generator client {
  provider = "prisma-client-js"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
//////////////////// ENUMS ///////////////////////////
//////////////////////////////////////////////////////

enum PartyType {
  CUSTOMER
  SUPPLIER
}

enum WorkStatus {
  PENDING
  RUNNING
  COMPLETED
  CANCELLED
}

enum AttendanceStatus {
  PRESENT
  ABSENT
}

enum InvoiceStatus {
  DRAFT
  SENT
  CANCELLED
}

enum LedgerReferenceType {
  INVOICE
  PAYMENT
  PURCHASE
  ADJUSTMENT
  OPENING_BALANCE
}

//////////////////////////////////////////////////////
//////////////////// PARTY ///////////////////////////
//////////////////////////////////////////////////////

model Party {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  gstNumber String?
  address   String?
  stateCode String?
  type      PartyType

  invoices    Invoice[] @relation("InvoiceParty")
  shippingFor Invoice[] @relation("InvoiceShipTo")

  quotations         Quotation[]
  chalans            Chalan[]
  chalansShippingFor Chalan[]    @relation("ChalanShipTo")

  payments      Payment[]
  ledgerEntries LedgerEntry[]
  workOrders    WorkOrder[]

  isActive Boolean @default(true)

  createdBy String?
  updatedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([type])
}

//////////////////////////////////////////////////////
//////////////////// WORKERS /////////////////////////
//////////////////////////////////////////////////////

model Worker {
  id          String  @id @default(uuid())
  name        String
  phone       String?
  skillType   String?
  defaultWage Decimal @db.Decimal(10, 2)

  isActive Boolean @default(true)

  attendances AttendanceItem[]

  createdAt DateTime @default(now())
}

//////////////////////////////////////////////////////
//////////////////// FINANCIAL YEAR //////////////////
//////////////////////////////////////////////////////

model FinancialYear {
  id String @id @default(uuid())

  label String @unique // "2025-26"

  startDate String?
  endDate   String?

  isActive Boolean @default(false)
  isClosed Boolean @default(false)

  createdAt DateTime @default(now())

  invoices Invoice[]
}

//////////////////////////////////////////////////////
//////////////////// WORK ORDER //////////////////////
//////////////////////////////////////////////////////

model WorkOrder {
  id String @id @default(uuid())

  title       String
  description String?

  partyId String?
  party   Party?  @relation(fields: [partyId], references: [id])

  status WorkStatus @default(PENDING)

  startDate String
  endDate   String?

  estimatedCost Decimal? @db.Decimal(12, 2)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([partyId])
  @@index([status])
}

//////////////////////////////////////////////////////
//////////////////// ATTENDANCE //////////////////////
//////////////////////////////////////////////////////

model AttendanceDay {
  id String @id @default(uuid())

  date DateTime @unique

  year  Int
  month Int
  day   Int

  items AttendanceItem[]

  @@index([year, month])
}

model AttendanceItem {
  id String @id @default(uuid())

  attendanceDayId String
  workerId        String

  status AttendanceStatus

  hoursWorked Float?
  wage        Decimal? @db.Decimal(10, 2)

  worker Worker @relation(fields: [workerId], references: [id], onDelete: Cascade)

  attendanceDay AttendanceDay @relation(fields: [attendanceDayId], references: [id], onDelete: Cascade)

  @@unique([attendanceDayId, workerId])
  @@index([workerId])
}

//////////////////////////////////////////////////////
//////////////////// QUOTATION ///////////////////////
//////////////////////////////////////////////////////

model Quotation {
  id String @id @default(uuid())

  partyId String
  party   Party  @relation(fields: [partyId], references: [id])

  issueDate DateTime
  month     Int?
  year      Int?
  items     QuotationItem[]

  taxableAmount Decimal @db.Decimal(12, 2)

  sgst Decimal @default(9) @db.Decimal(12, 2)
  cgst Decimal @default(9) @db.Decimal(12, 2)
  igst Decimal @default(0) @db.Decimal(12, 2)

  roundOff    Decimal @default(0) @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  status InvoiceStatus @default(DRAFT)

  createdAt DateTime @default(now())

  @@index([partyId])
}

model QuotationItem {
  id String @id @default(uuid())

  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  description    String
  subdescription String[]

  hsnCode String?
  unit    String?

  quantity Int     @default(1)
  rate     Decimal @db.Decimal(10, 2)
  amount   Decimal @db.Decimal(12, 2)

  @@index([quotationId])
}

//////////////////////////////////////////////////////
//////////////////// INVOICE /////////////////////////
//////////////////////////////////////////////////////

model Invoice {
  id String @id @default(uuid())

  invoiceNumber String   @unique
  issueDate     DateTime

  month Int?
  year  Int?

  partyId String
  party   Party  @relation("InvoiceParty", fields: [partyId], references: [id])

  shipToId String?
  shipTo   Party?  @relation("InvoiceShipTo", fields: [shipToId], references: [id])

  chNo      String?
  poNo      String?
  stateCode String?

  items InvoiceItem[]

  taxableAmount Decimal @db.Decimal(12, 2)

  sgst Decimal @default(9) @db.Decimal(12, 2)
  cgst Decimal @default(9) @db.Decimal(12, 2)
  igst Decimal @default(0) @db.Decimal(12, 2)

  roundOff    Decimal @default(0) @db.Decimal(12, 2)
  totalAmount Decimal @db.Decimal(12, 2)

  status InvoiceStatus @default(DRAFT)

  financialYearId String?
  financialYear   FinancialYear? @relation(fields: [financialYearId], references: [label])

  createdAt DateTime @default(now())
  chalans   Chalan[]

  @@index([partyId])
  @@index([issueDate])
  @@index([financialYearId])
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  description    String
  subdescription String[]

  hsnCode String?
  unit    String?

  quantity Int     @default(1)
  rate     Decimal @db.Decimal(10, 2)
  amount   Decimal @db.Decimal(12, 2)

  @@index([invoiceId])
}

//////////////////////////////////////////////////////
//////////////////// CHALAN //////////////////////////
//////////////////////////////////////////////////////

model Chalan {
  id        String   @id @default(uuid())
  invoiceId String?
  invoice   Invoice? @relation(fields: [invoiceId], references: [id])

  partyId String
  party   Party  @relation(fields: [partyId], references: [id])

  shipToId  String?
  shipTo    Party?  @relation("ChalanShipTo", fields: [shipToId], references: [id])
  month     Int?
  year      Int?
  chNo      String
  vehicleNo String?

  issueDate DateTime

  status InvoiceStatus @default(DRAFT)

  items ChalanItem[]

  @@index([partyId])
}

model ChalanItem {
  id String @id @default(uuid())

  chalanId String
  chalan   Chalan @relation(fields: [chalanId], references: [id], onDelete: Cascade)

  description    String
  subdescription String[]

  hsnCode String?
  unit    String?

  quantity Int  @default(1)
  weight   Int?

  @@index([chalanId])
}

//////////////////////////////////////////////////////
//////////////////// PAYMENTS ////////////////////////
//////////////////////////////////////////////////////
// paryment model deal with payment we give or payment reviced

model Payment {
  id String @id @default(uuid())

  partyId   String
  party     Party     @relation(fields: [partyId], references: [id])
  partyType PartyType 

  amount    Decimal   @db.Decimal(12, 2)
  
  method String?
  note   String?

  paymentDate DateTime

  ledgerEntries LedgerEntry[]

  createdAt DateTime @default(now())

  @@index([partyId])
  @@index([paymentDate])
}

//////////////////////////////////////////////////////
//////////////////// LEDGER //////////////////////////
//////////////////////////////////////////////////////

model LedgerEntry {
  id String @id @default(uuid())

  partyId String
  party   Party  @relation(fields: [partyId], references: [id])

  year  Int
  month Int

  referenceType LedgerReferenceType
  referenceId   String?

  description String?

  debit  Decimal @default(0) @db.Decimal(12, 2)
  credit Decimal @default(0) @db.Decimal(12, 2)

  date DateTime

  paymentId String?
  payment   Payment? @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())

  @@index([partyId, year, month])
  @@index([partyId, date])
  @@index([referenceId])
}
